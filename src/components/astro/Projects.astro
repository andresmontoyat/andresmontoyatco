---
// src/components/astro/Projects.astro
// Zero-client-JS port of src/components/Projects.jsx (v5 STATIC-01).
// FeaturedProjectCard / ProjectCard / TechTags sub-components inlined directly
// into the featured.map() / rest.map() template blocks — Astro components
// cannot be invoked as plain JS functions the way React sub-components were.
import data from '../../data/projects.json'

const { locale } = Astro.props

function pick(field, lang) {
  if (typeof field === 'string') return field
  return field?.[lang] ?? field?.en ?? ''
}

const ctaLive = pick(data.ctaLive, locale)
const ctaGithub = pick(data.ctaGithub, locale)
const featuredLabel = pick(data.featuredLabel, locale)
const featured = data.projects.filter((p) => p.featured)
const rest = data.projects.filter((p) => !p.featured)
---
<section id="projects" class="py-20">
  <div class="max-w-6xl mx-auto px-6">
    <div class="font-pixel text-[10px] uppercase tracking-[1px] text-accent flex items-center gap-3 mb-4">
      <span class="block w-10 h-0.5 bg-accent" /> {pick(data.label, locale)}
    </div>
    <h2 class="font-pixel text-lg sm:text-xl md:text-2xl font-extrabold tracking-normal text-text mb-4 leading-tight">
      {pick(data.h2, locale)}
    </h2>
    <p class="text-muted max-w-[640px] mb-12 font-pixel text-[11px] leading-[2]">{pick(data.intro, locale)}</p>
    {featured.map((project) => {
      const title = pick(project.title, locale)
      const desc = pick(project.desc, locale)
      return (
        <div class="mb-6">
          <article
            data-featured="true"
            class="group relative w-full overflow-hidden rounded-2xl border border-accent/50 bg-surface shadow-[0_0_45px_-14px_var(--accent)] transition-all duration-300 hover:border-accent hover:-translate-y-1"
          >
            <span aria-hidden="true" class="absolute left-0 top-0 h-full w-1 bg-gradient-to-b from-accent to-secondary" />
            <div class="grid md:grid-cols-[280px_1fr]">
              <div class="relative flex aspect-video items-center justify-center overflow-hidden bg-bg md:aspect-auto">
                <div class="absolute inset-0 bg-grad-accent opacity-[0.16] transition-opacity duration-300 group-hover:opacity-25" />
                <span class="relative text-6xl transition-transform duration-300 group-hover:scale-110" aria-hidden="true">{project.icon || '◆'}</span>
              </div>
              <div class="p-8">
                <span class="inline-flex items-center gap-1.5 font-mono text-[10px] uppercase tracking-[2px] text-accent mb-3">
                  <span aria-hidden="true">★</span> {featuredLabel}
                </span>
                <h3 class="text-xl sm:text-2xl font-extrabold text-text leading-tight">{title}</h3>
                <p class="text-base text-muted mt-2 leading-relaxed">{desc}</p>
                <div class="flex flex-wrap gap-2 mt-4">
                  {project.tech.map((tag) => (
                    <span class="font-mono text-xs px-2 py-1 rounded-md bg-bg text-muted border border-border transition-colors duration-150 group-hover:border-accent/40">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </article>
        </div>
      )
    })}
    <div class="flex flex-wrap justify-center gap-6">
      {rest.map((project) => {
        const title = pick(project.title, locale)
        const desc = pick(project.desc, locale)
        return (
          <div class="w-full sm:w-[360px]">
            <article data-featured="false" class="group bg-surface border border-border rounded-xl overflow-hidden transition-all duration-300 hover:border-accent hover:-translate-y-1">
              <div class="relative aspect-video w-full overflow-hidden bg-bg">
                <div class="absolute inset-0 bg-grad-accent opacity-[0.12] transition-opacity duration-300 group-hover:opacity-20" />
                <div class="relative w-full h-full flex items-center justify-center">
                  <span class="text-5xl" aria-hidden="true">{project.icon || '◆'}</span>
                </div>
              </div>
              <div class="p-6">
                <h3 class="text-base font-extrabold text-text">{title}</h3>
                <p class="text-base text-muted mt-2">{desc}</p>
                <div class="flex flex-wrap gap-2 mt-4">
                  {project.tech.map((tag) => (
                    <span class="font-mono text-xs px-2 py-1 rounded-md bg-bg text-muted border border-border">
                      {tag}
                    </span>
                  ))}
                </div>
                {(project.liveUrl || project.githubUrl) && (
                  <div class="flex gap-3 mt-5">
                    {project.liveUrl && (
                      <a
                        href={project.liveUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-sm font-semibold text-accent hover:underline"
                      >
                        {ctaLive}
                      </a>
                    )}
                    {project.githubUrl && (
                      <a
                        href={project.githubUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-sm font-semibold text-text hover:text-accent hover:underline"
                      >
                        {ctaGithub}
                      </a>
                    )}
                  </div>
                )}
              </div>
            </article>
          </div>
        )
      })}
    </div>
  </div>
</section>
