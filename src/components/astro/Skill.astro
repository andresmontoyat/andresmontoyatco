---
// src/components/astro/Skill.astro
// Zero-client-JS port of src/components/Skill.jsx (v5 STATIC-01).
// MeterRow/Category React sub-components are inlined into the template's
// .map() blocks — Astro components cannot be invoked as plain JS functions
// the way React sub-components were (D-01).
import data from '../../data/skills.json'

const { locale } = Astro.props

function pick(field, lang) {
  if (typeof field === 'string') return field
  return field?.[lang] ?? field?.en ?? ''
}

function maxYears() {
  return Math.max(...data.categories.flatMap((c) => c.chips).map((ch) => ch.years))
}

const suffix = pick(data.yearsSuffix, locale)
const max = maxYears()
---
<section id="skills" class="py-20">
  <div class="max-w-6xl mx-auto px-6">
    <div class="font-pixel text-[10px] uppercase tracking-[1px] text-accent flex items-center gap-3 mb-4">
      <span class="block w-10 h-0.5 bg-accent" /> {pick(data.label, locale)}
    </div>
    <h2 class="font-pixel text-lg sm:text-xl md:text-2xl font-extrabold tracking-normal text-text mb-4 leading-tight">
      {pick(data.h2, locale)}
    </h2>
    <p class="text-muted max-w-[640px] mb-12 font-pixel text-[11px] leading-[2]">{pick(data.intro, locale)}</p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 items-start">
      {data.categories.map((category) => (
        <div class="group/card bg-surface/40 border border-border rounded-[16px] p-6 transition-colors duration-200 hover:border-accent/40">
          <h3 class="text-base font-extrabold mb-4 flex items-center gap-2 text-text">
            <span class="text-accent transition-transform duration-200 group-hover/card:scale-125">{category.symbol}</span> {pick(category.title, locale)}
          </h3>
          <div class="flex flex-col gap-1">
            {category.chips.map((chip) => {
              const fill = Math.max(8, Math.round((chip.years / max) * 100))
              return (
                <div
                  data-core={chip.core ? 'true' : 'false'}
                  class="group -mx-2 rounded-lg px-2 py-1.5 transition-colors duration-200 hover:bg-accent/[0.06]"
                >
                  <div class="flex items-baseline justify-between mb-1.5 gap-3">
                    <span class={`text-sm transition-colors duration-200 ${chip.core ? 'font-bold text-accent' : 'text-text/80 group-hover:text-text'}`}>{chip.label}</span>
                    <span class="font-mono text-[11px] text-muted shrink-0 transition-colors duration-200 group-hover:text-accent">{chip.years}{suffix}</span>
                  </div>
                  <div class="h-2 rounded-full bg-white/[0.07] overflow-hidden">
                    <div
                      class={`h-full rounded-full transition-all duration-300 ${chip.core ? 'bg-gradient-to-r from-accent to-secondary shadow-[0_0_8px_rgba(0,229,168,0.55)]' : 'bg-accent/55 group-hover:bg-accent group-hover:shadow-[0_0_8px_rgba(0,229,168,0.45)]'}`}
                      style={`width: ${fill}%`}
                    />
                  </div>
                </div>
              )
            })}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
