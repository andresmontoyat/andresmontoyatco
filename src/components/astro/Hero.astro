---
// src/components/astro/Hero.astro
// Zero-client-JS port of the former React Hero component (v5 STATIC-02, Hero half; deleted 24-04).
// Char-reveal H1 -> CSS steps() width-reveal animation (D-01), zero JS.
// CV dropdown -> native <details>/<summary> with the ARIA menu/menuitem
// roles DELIBERATELY DROPPED (D-05) — native disclosure semantics are
// already correct; those roles implied arrow-key menu navigation that was
// never actually implemented, even in the React version. Stats -> spans
// wired to the shared count-up enhancer script (D-02). Hero photo ports
// directly as the server-rendered LCP element — no duplicate-DOM static
// workaround (D-08); BaseLayout.astro only carries the preload hint.
import translations from '../../i18n/translations.js'

const { locale } = Astro.props
const t = translations[locale] ?? translations.en

const midLine = t.hero.h1b
const charCount = midLine.length

function statParts(num) {
  const match = num.match(/\d+/)
  const target = match ? Number(match[0]) : 0
  const template = match ? num.replace(/\d+/, '{n}') : num
  return { target, template }
}

const yearsStat = statParts('18+')
const teamStat = statParts('45+')
const companiesStat = statParts('15+')
const industriesStat = statParts('8')

const liAria = locale === 'es' ? 'Perfil de LinkedIn' : 'LinkedIn profile'
const ghAria = locale === 'es' ? 'Perfil de GitHub' : 'GitHub profile'
---
<section id="hero" class="relative min-h-screen flex items-center pt-16 pb-16 overflow-hidden">
  <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <img
      src="/me-800.webp"
      srcset="/me-400.webp 400w, /me-800.webp 800w, /me-1600.webp 1600w"
      sizes="100vw"
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
      style={`object-position: center 30%; filter: var(--hero-photo-filter);`}
    />
    <div class="absolute inset-0" style="background: var(--hero-overlay);" />
  </div>

  <div class="relative z-10 max-w-6xl mx-auto px-6 py-20 w-full">
    <span
      class="inline-flex items-center gap-2 px-4 py-1.5 border border-ink-400 rounded-full font-mono text-xs text-text-secondary bg-ink-500 mb-6 motion-safe:opacity-0 motion-safe:animate-fade-in"
      style="animation-delay: 0ms; animation-fill-mode: forwards; animation-duration: 500ms;"
    >
      <span class="w-2 h-2 rounded-full bg-brand motion-safe:animate-pulse2 shadow-[0_0_12px_var(--color-brand)]" />
      {t.hero.status}
    </span>

    <h1
      class="font-pixel text-xl sm:text-3xl lg:text-4xl font-extrabold tracking-normal leading-[1.5] mb-7"
      aria-label={`${t.hero.h1a} ${t.hero.h1b} ${t.hero.h1c}`}
      style="filter: drop-shadow(var(--hero-h1-shadow));"
    >
      <span
        class="block text-text-primary motion-safe:opacity-0 motion-safe:animate-slide-up"
        style="animation-delay: 150ms; animation-fill-mode: forwards; animation-duration: 600ms;"
      >
        {t.hero.h1a}
      </span>
      <span
        class="block motion-safe:opacity-0 motion-safe:animate-fade-in"
        style="animation-delay: 300ms; animation-fill-mode: forwards; animation-duration: 500ms;"
        aria-hidden="true"
      >
        <span
          class="hero-reveal inline-block overflow-hidden whitespace-nowrap align-bottom bg-brand-gradient bg-clip-text text-transparent"
          style={`--reveal-chars: ${charCount}`}
        >{midLine}</span>
      </span>
      <span
        class="block text-text-primary motion-safe:opacity-0 motion-safe:animate-slide-up"
        style="animation-delay: 500ms; animation-fill-mode: forwards; animation-duration: 600ms;"
      >
        {t.hero.h1c}
      </span>
    </h1>

    <p
      class="font-pixel text-[11px] sm:text-xs text-text-secondary max-w-2xl mb-9 leading-[2] motion-safe:opacity-0 motion-safe:animate-slide-up"
      style="animation-delay: 600ms; animation-fill-mode: forwards; animation-duration: 600ms;"
    >
      {t.hero.lead}
    </p>

    <div
      class="relative z-30 flex items-center gap-3 flex-wrap motion-safe:opacity-0 motion-safe:animate-slide-up"
      style="animation-delay: 800ms; animation-fill-mode: forwards; animation-duration: 600ms;"
    >
      <a
        href="#contact"
        class="inline-flex items-center gap-2 min-h-[44px] px-6 py-3 rounded-full font-extrabold text-xs font-mono bg-brand-gradient text-ink-900 shadow-brand hover:shadow-brand-lg transform hover:-translate-y-0.5 transition-all"
      >
        {t.hero.cta1} →
      </a>

      <!-- D-05: the ARIA menu/menuitem roles are deliberately dropped here.
           Native <details>/<summary> disclosure semantics are already
           correct without extra ARIA — those roles implied arrow-key menu
           navigation that was never actually implemented, even in the
           React version this replaces. This is a deliberate a11y choice,
           not an oversight. -->
      <details class="details-dismiss relative group">
        <summary class="inline-flex items-center gap-2 min-h-[44px] px-4 py-3 rounded-full font-extrabold text-xs font-mono bg-transparent text-text-primary border border-ink-400 hover:border-brand hover:text-brand transition-colors cursor-pointer list-none [&::-webkit-details-marker]:hidden">
          <span aria-hidden="true">⬇</span> {t.hero.cv}
          <span aria-hidden="true" class="transition-transform duration-200 group-open:rotate-180">▾</span>
        </summary>
        <div class="absolute left-0 mt-2 min-w-[160px] rounded-xl border border-ink-400 bg-ink-900/95 backdrop-blur-md p-1 z-50 shadow-brand-lg">
          <a href="/CarlosMontoya_CV_EN.pdf" download class="block px-4 py-2 rounded-lg text-xs font-mono text-text-secondary hover:bg-ink-500 hover:text-brand transition-colors">{t.hero.cvEn}</a>
          <a href="/CarlosMontoya_CV_ES.pdf" download class="block px-4 py-2 rounded-lg text-xs font-mono text-text-secondary hover:bg-ink-500 hover:text-brand transition-colors">{t.hero.cvEs}</a>
        </div>
      </details>

      <div class="flex items-center gap-2 ml-1">
        <a
          href="https://www.linkedin.com/in/carlos-andres-montoya-tobon-8b508033"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={liAria}
          class="inline-flex items-center justify-center w-11 h-11 rounded-full border border-ink-400 text-text-secondary hover:border-brand hover:text-brand transition-colors"
        >
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
          </svg>
        </a>
        <a
          href="https://github.com/andresmontoyat"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={ghAria}
          class="inline-flex items-center justify-center w-11 h-11 rounded-full border border-ink-400 text-text-secondary hover:border-brand hover:text-brand transition-colors"
        >
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222 0 1.606-.014 2.898-.014 3.293 0 .322.216.694.825.576C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
          </svg>
        </a>
      </div>
    </div>

    <div
      class="grid grid-cols-2 sm:grid-cols-4 gap-4 mt-12 p-7 bg-gradient-to-b from-ink-500 to-ink-700 border border-ink-400 rounded-xl motion-safe:opacity-0 motion-safe:animate-fade-in backdrop-blur-sm shadow-brand"
      style="animation-delay: 850ms; animation-fill-mode: forwards; animation-duration: 500ms;"
    >
      <div class="group text-center cursor-default motion-safe:transition-transform motion-safe:duration-200 motion-safe:hover:-translate-y-1">
        <div
          class="text-3xl font-extrabold leading-none bg-brand-gradient bg-clip-text text-transparent transition-transform duration-200 group-hover:scale-110 motion-safe:group-hover:drop-shadow-[0_0_10px_rgba(37,99,235,0.5)]"
          data-count-up={yearsStat.target}
          data-count-up-template={yearsStat.template}
        >18+</div>
        <div class="mt-1 text-xs font-mono font-normal text-text-secondary uppercase tracking-widest transition-colors duration-200 group-hover:text-brand">{t.stats.years}</div>
      </div>
      <div class="group text-center cursor-default motion-safe:transition-transform motion-safe:duration-200 motion-safe:hover:-translate-y-1">
        <div
          class="text-3xl font-extrabold leading-none bg-brand-gradient bg-clip-text text-transparent transition-transform duration-200 group-hover:scale-110 motion-safe:group-hover:drop-shadow-[0_0_10px_rgba(37,99,235,0.5)]"
          data-count-up={teamStat.target}
          data-count-up-template={teamStat.template}
        >45+</div>
        <div class="mt-1 text-xs font-mono font-normal text-text-secondary uppercase tracking-widest transition-colors duration-200 group-hover:text-brand">{t.stats.team}</div>
      </div>
      <div class="group text-center cursor-default motion-safe:transition-transform motion-safe:duration-200 motion-safe:hover:-translate-y-1">
        <div
          class="text-3xl font-extrabold leading-none bg-brand-gradient bg-clip-text text-transparent transition-transform duration-200 group-hover:scale-110 motion-safe:group-hover:drop-shadow-[0_0_10px_rgba(37,99,235,0.5)]"
          data-count-up={companiesStat.target}
          data-count-up-template={companiesStat.template}
        >15+</div>
        <div class="mt-1 text-xs font-mono font-normal text-text-secondary uppercase tracking-widest transition-colors duration-200 group-hover:text-brand">{t.stats.companies}</div>
      </div>
      <div class="group text-center cursor-default motion-safe:transition-transform motion-safe:duration-200 motion-safe:hover:-translate-y-1">
        <div
          class="text-3xl font-extrabold leading-none bg-brand-gradient bg-clip-text text-transparent transition-transform duration-200 group-hover:scale-110 motion-safe:group-hover:drop-shadow-[0_0_10px_rgba(37,99,235,0.5)]"
          data-count-up={industriesStat.target}
          data-count-up-template={industriesStat.template}
        >8</div>
        <div class="mt-1 text-xs font-mono font-normal text-text-secondary uppercase tracking-widest transition-colors duration-200 group-hover:text-brand">{t.stats.industries}</div>
      </div>
    </div>
  </div>
</section>

<script src="../../scripts/count-up.js"></script>
<script src="../../scripts/details-dismiss.js"></script>
